VPC_SUBNET_IDS=subnet-xxxxx,subnet-xxxxx
VPC_SECURITY_GROUP_IDS=sg-xxxxx,sg-xxxxx

# KMS Encryption
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx

# Custom Domain
