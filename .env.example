## Development & Testing

```
# Development Mode
DEBUG_MODE=true
DEBUG_LOGGING=true
MOCK_AWS_RESPONSES=false               # Set true to mock AWS for local testing

# Testing
TEST_ENVIRONMENT=local                 # local, staging, production
TEST_PHONE_NUMBER=+1-800-XXXX
TEST_AGENT_USERNAME=test-agent@connect
TEST_CONTACT_ID=test-contact-123

# Endpoints
API_BASE_URL=https://api.example.com
API_TIMEOUT_SECONDS=30

# Features
ENABLE_CALL_RECORDING=true
ENABLE_CUSTOMER_PROFILES=false         # (Bonus feature)
ENABLE_ANALYTICS=true
```

