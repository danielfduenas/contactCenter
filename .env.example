## iOS Configuration

```
# AWS SDK Configuration
IOS_AWS_ACCESS_KEY_ID=AKIA...
IOS_AWS_SECRET_ACCESS_KEY=...          # ⚠️ KEEP SECRET!
IOS_AWS_REGION=us-east-1

# Connect Instance
IOS_CONNECT_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
IOS_CONNECT_INSTANCE_URL=https://account-id.awsapps.com/connect

# Contact Flow
IOS_CONTACT_FLOW_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Permissions
IOS_MICROPHONE_PERMISSION_TEXT=This app needs microphone access to make calls
IOS_REQUEST_MICROPHONE_ON_STARTUP=true

# Logging
IOS_LOG_LEVEL=debug                    # debug, info, warning, error
IOS_ENABLE_CLOUDWATCH_LOGGING=true
```

---

## Android Configuration

```
# AWS SDK Configuration
ANDROID_AWS_ACCESS_KEY_ID=AKIA...
ANDROID_AWS_SECRET_ACCESS_KEY=...      # ⚠️ KEEP SECRET!
ANDROID_AWS_REGION=us-east-1

# Connect Instance
ANDROID_CONNECT_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ANDROID_CONNECT_INSTANCE_URL=https://account-id.awsapps.com/connect

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=XXXXXXXXXXXXXXXX      # ⚠️ KEEP SECRET!
FIREBASE_SENDER_ID=123456789012
FIREBASE_DATABASE_URL=https://...

# CCP Configuration
ANDROID_CCP_URL=https://account-id.awsapps.com/connect/ccp-v2/
ANDROID_CCP_REFRESH_INTERVAL=60000     # milliseconds

# Notifications
ANDROID_NOTIFICATION_CHANNEL_ID=amazon_connect_calls
ANDROID_NOTIFICATION_SOUND=default
ANDROID_ENABLE_VIBRATION=true

# Permissions
ANDROID_REQUEST_RECORD_AUDIO=true
ANDROID_REQUEST_NOTIFICATION=true

# Logging
ANDROID_LOG_LEVEL=DEBUG                # DEBUG, INFO, WARN, ERROR
ANDROID_ENABLE_FIREBASE_ANALYTICS=true
```

